# Server
NODE_ENV=development
HOST=0.0.0.0
PORT=8080

# Google Maps
# Server key is used only by the backend for Google Directions API calls.
GOOGLE_MAPS_SERVER_KEY=your_google_maps_server_key_here

# Browser key is exposed by Vite and used only by the frontend map view.
VITE_GOOGLE_MAPS_BROWSER_KEY=your_google_maps_browser_key_here

# Google Directions response preferences.
GOOGLE_DIRECTIONS_LANGUAGE=en
GOOGLE_DIRECTIONS_REGION=ca
